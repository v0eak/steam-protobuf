{
  "name": "steam-protobuf",
  "version": "1.0.6",
  "description": "TypeScript Library for Steam Protobuf Encoding & Decoding",
  "author": {
    "name": "v0eak"
  },
  "license": "MIT",
  "keywords": [
    "steam",
    "protobuf"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v0eak/steam-protobuf.git"
  },
  "bugs": {
    "url": "https://github.com/v0eak/steam-protobuf/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.0",
  "exports": {
    ".": {
      "default": "./.dist/index.js",
      "types": "./.dist/index.d.ts"
    }
  },
  "files": [
    ".dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "yarn rimraf .dist",
    "gen": "yarn tsx scripts/generate.ts $(node -e \"console.log(require('which').sync('protoc-gen-ts_proto'))\")",
    "build": "yarn clean && yarn gen && tsc"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "^26.0.0",
    "giget": "^3.3.0",
    "prettier": "^3.8.4",
    "protoc": "25.9.0",
    "rimraf": "^6.1.3",
    "ts-dedent": "^2.3.0",
    "ts-proto": "2.11.8",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "which": "^7.0.0"
  }
}
